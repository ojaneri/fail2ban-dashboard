AuthType Basic
AuthName "Área Restrita - Fail2Ban Dashboard"
AuthUserFile /var/www/html/perito.digital/dashboard/.htpasswd
Require valid-user

# Enable Rewrite Engine
RewriteEngine On

# Forward WebSocket connections (must come before the general rule)
RewriteCond %{HTTP:Upgrade} =WebSocket [NC]
RewriteRule ^(.*)$ ws://localhost:8000/$1 [P,L]

# Forward everything else to the backend on port 8000
RewriteRule ^$ http://localhost:8000/ [P,L]
RewriteRule ^(.*)$ http://localhost:8000/$1 [P,L]
